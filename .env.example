VITE_SUPABASE_URL=https://xsmnfcmtbpeaccnyinkr.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional. Free Books API key (no billing) → private quota for book lookups.
# console.cloud.google.com → enable Books API → Credentials → API key.
# Without it, book enrichment falls back to Open Library + Claude.
VITE_GOOGLE_BOOKS_KEY=
# Optional. TMDB v3 "API Key" (api_key field) for movie/TV enrichment —
# poster, year, runtime, genres, director/creator, overview.
# themoviedb.org/settings/api. Safe client-side. Falls back to the older
# VITE_TMDB_API_KEY name. Without it, movie/TV enrichment falls back to Claude.
VITE_TMDB_KEY=
